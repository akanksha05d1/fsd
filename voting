import React, { useState } from "react";

function App() {
  const [a, setA] = useState(0);
  const [b, setB] = useState(0);

  return (
    <div>
      <h3>A: {a}</h3>
      <button onClick={() => setA(a + 1)}>Vote A</button>

      <h3>B: {b}</h3>
      <button onClick={() => setB(b + 1)}>Vote B</button>
    </div>
  );
}

export default App;
