<!DOCTYPE html>
<html ng-app="app"> <!-- Initialize AngularJS app -->
<head>
    <title>Job Registration</title>

    <!-- AngularJS CDN -->
    <script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>

    <!-- Simple CSS -->
    <style>
        form {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
    </style>
</head>

<body ng-controller="ctrl"> <!-- Connect controller -->

    <h2>Job Registration Form</h2>

    <!-- Form with submit event -->
    <form ng-submit="submit()">

        <!-- Name input (required validation) -->
        <input type="text" ng-model="name" placeholder="Name" required>

        <!-- Email input (required + email validation) -->
        <input type="email" ng-model="email" placeholder="Email" required>

        <!-- Dropdown for job position -->
        <select ng-model="position" required>
            <option value="" disabled selected>Select Position</option>
            <option>Developer</option>
            <option>Designer</option>
            <option>Tester</option>
        </select>

        <!-- Submit button -->
        <button type="submit">Register</button>

    </form>

    <!-- Display message after successful submission -->
    <p>{{msg}}</p>

    <script>
        // Create AngularJS module
        angular.module("app", [])

        // Create controller
        .controller("ctrl", function($scope) {

            // Function called on form submit
            $scope.submit = function() {

                // Create success message using user input
                $scope.msg = "Job Registered for " + $scope.name + " as " + $scope.position;
            };
        });
    </script>

</body>
</html>
